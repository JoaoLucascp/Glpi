{# templates/companydata/sections/empresa.html.twig #}
<form method="post" action="{{ form_url }}">
	<input type="hidden" name="id"               value="{{ item_id }}">
	<input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token }}">
	{# entities_id obrigatório para CommonDBTM::update() funcionar corretamente #}
	<input type="hidden" name="entities_id"      value="{{ data.entities_id ?? 0 }}">

	{# ── ADD vs UPDATE: distingue criação de edição ─────────────────────── #}
	{% if item_id > 0 %}
		<input type="hidden" name="update" value="1">
	{% else %}
		<input type="hidden" name="add" value="1">
	{% endif %}

	{# ── Informações Gerais ── #}
	<div class="card mb-3">
		<div class="card-header">
			<i class="ti ti-building me-2"></i>
			<strong>Informações Gerais</strong>
		</div>
		<div class="card-body">
			<div class="row g-3">
				<div class="col-12 col-lg-1">
					<label class="form-label">ID</label>
					<input type="text" class="form-control" value="{{ item_id }}" readonly disabled>
				</div>
				<div class="col-12 col-lg-5">
					<label class="form-label">Nome Fantasia</label>
					<input type="text" name="fantasy_name" value="{{ data.fantasy_name ?? '' }}" class="form-control" placeholder="Ex: NEWTEL SOLUCOES">
				</div>
				<div class="col-12 col-lg-6">
					<label class="form-label">CNPJ</label>
					<div class="input-group">
						<input type="text" name="cnpj" value="{{ data.cnpj ?? '' }}" class="form-control" placeholder="00.000.000/0000-00" maxlength="18">
						<button type="button" class="btn btn-secondary" data-action="search-cnpj">
							<i class="ti ti-search"></i>
						</button>
					</div>
				</div>
				<div class="col-12 col-lg-6">
					<label class="form-label">Razão Social
						<span class="text-red">*</span>
					</label>
					<input type="text" name="corporate_name" value="{{ data.corporate_name ?? '' }}" class="form-control" placeholder="Razão Social completa">
				</div>
				<div class="col-12 col-lg-6">
					<label class="form-label">E-mail</label>
					<input type="email" name="email" value="{{ data.email ?? '' }}" class="form-control" placeholder="contato@empresa.com.br">
				</div>
				<div class="col-12 col-lg-6">
					<label class="form-label">Telefone</label>
					<input type="text" name="phone" value="{{ data.phone ?? '' }}" class="form-control" placeholder="(27) 3372-7000">
				</div>
			</div>
		</div>
	</div>

	{# ── Endereço ── #}
	<div class="card mb-3">
		<div class="card-header">
			<i class="ti ti-map-pin me-2"></i>
			<strong>Endereço</strong>
		</div>
		<div class="card-body">
			<div class="row g-3">
				<div class="col-12 col-lg-4">
					<label class="form-label">CEP</label>
					<div class="input-group">
						<input type="text" name="cep" value="{{ data.cep ?? '' }}" class="form-control" placeholder="00000-000">
						<button type="button" class="btn btn-secondary" data-action="search-cep">
							<i class="ti ti-search"></i>
						</button>
					</div>
				</div>
				<div class="col-12 col-lg-6">
					<label class="form-label">Rua</label>
					<input type="text" name="street" value="{{ data.street ?? '' }}" class="form-control" placeholder="Nome da rua">
				</div>
				<div class="col-12 col-lg-2">
					<label class="form-label">Número</label>
					<input type="text" name="number" value="{{ data.number ?? '' }}" class="form-control" placeholder="Ex: 224">
				</div>
				<div class="col-12 col-lg-4">
					<label class="form-label">Complemento</label>
					<input type="text" name="complement" value="{{ data.complement ?? '' }}" class="form-control" placeholder="Loja, Sala, Apto...">
				</div>
				<div class="col-12 col-lg-4">
					<label class="form-label">Bairro</label>
					<input type="text" name="neighborhood" value="{{ data.neighborhood ?? '' }}" class="form-control" placeholder="Nome do bairro">
				</div>
				<div class="col-12 col-lg-4">
					<label class="form-label">Cidade</label>
					<input type="text" name="city" value="{{ data.city ?? '' }}" class="form-control" placeholder="Cidade">
				</div>
				<div class="col-12 col-lg-2">
					<label class="form-label">Estado</label>
					<input type="text" name="state" value="{{ data.state ?? '' }}" class="form-control" placeholder="ES" maxlength="2">
				</div>
				<div class="col-12 col-lg-4">
					<label class="form-label">País</label>
					<input type="text" name="country" value="{{ data.country ?? 'Brasil' }}" class="form-control">
				</div>
				<div class="col-12 col-lg-3">
					<label class="form-label">Latitude</label>
					<input type="text" name="latitude" value="{{ data.latitude ?? '' }}" class="form-control" placeholder="-20.12345678">
				</div>
				<div class="col-12 col-lg-3">
					<label class="form-label">Longitude</label>
					<input type="text" name="longitude" value="{{ data.longitude ?? '' }}" class="form-control" placeholder="-40.12345678">
				</div>
			</div>
		</div>
	</div>

	{# ── Status da Empresa ── #}
	<div class="card mb-3">
		<div class="card-header">
			<i class="ti ti-file-check me-2"></i>
			<strong>Status da Empresa</strong>
		</div>
		<div class="card-body">
			<div class="row g-3">
				<div class="col-12 col-lg-4">
					<label class="form-label">Status do Contrato</label>
					<select name="contract_status" class="form-select">
						<option value="active"    {{ (data.contract_status ?? 'active') == 'active'    ? 'selected' : '' }}>Com contrato ativo</option>
						<option value="inactive"  {{ (data.contract_status ?? '') == 'inactive'        ? 'selected' : '' }}>Sem contrato</option>
						<option value="cancelled" {{ (data.contract_status ?? '') == 'cancelled'       ? 'selected' : '' }}>Contrato cancelado</option>
					</select>
				</div>
				<div class="col-12 col-lg-4">
					<label class="form-label">Data de Cadastro</label>
					{#
					  GLPI armazena date_creation como datetime: "2026-03-03 14:26:02"
					  <input type="date"> só exibe corretamente "YYYY-MM-DD" (10 chars).
					  Sem name= para não sobrescrever o valor gerenciado pelo GLPI.
					#}
					<input type="date"
					       value="{{ data.date_creation is not empty ? data.date_creation|slice(0, 10) : '' }}"
					       class="form-control"
					       readonly>
				</div>
				<div class="col-12 col-lg-4">
					<label class="form-label">Data de Encerramento</label>
					<input type="date" name="date_end"
					       value="{{ data.date_end is not empty ? data.date_end|slice(0, 10) : '' }}"
					       class="form-control">
				</div>
				<div class="col-12">
					<label class="form-label">Observações</label>
					<textarea name="notes" class="form-control" rows="4" placeholder="Observações adicionais...">{{ data.notes ?? '' }}</textarea>
				</div>
			</div>
		</div>
	</div>

	<div class="text-end mt-3 pb-2">
		<button type="submit" class="btn btn-primary">
			<i class="ti ti-device-floppy me-2"></i>
			Salvar Empresa
		</button>
	</div>
</form>
